{
  "name": "cross-connection",
  "version": "0.2.4",
  "description": "Security-first Axios alternative HTTP client for TypeScript, Node.js, and browsers with retries, SSRF protection, interceptors, and cancellation",
  "author": "Pratul Makae <pratulmakar02@gmail.com> (https://github.com/pratul03)",
  "homepage": "https://cross-connection-ui.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pratul03/cross-connection.git"
  },
  "bugs": {
    "url": "https://github.com/pratul03/cross-connection/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:all": "npm audit --audit-level=high",
    "prepublishOnly": "npm run test && npm run build && npm run audit:prod"
  },
  "keywords": [
    "cross-connection",
    "crossconnection",
    "http",
    "http-client",
    "typescript",
    "fetch",
    "axios",
    "axios-alternative",
    "interceptors",
    "cancelation",
    "cancellation",
    "retry-backoff",
    "telemetry",
    "security",
    "ssrf",
    "retry"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
