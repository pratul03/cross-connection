{
  "name": "cross-connection",
  "version": "0.2.1",
  "description": "Security-first Axios-like HTTP client with SSRF mitigation, retry backoff, and request fingerprinting",
  "author": "Pratul Makae <pratulmakar02@gmail.com> (https://github.com/pratul03)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "http",
    "axios",
    "security",
    "ssrf",
    "retry"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
